{
  "name": "navi-payload",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenvx run -f .env.development -- next dev",
    "dev:system-env": "NEXT_WEBPACK=1 next dev",
    "build": "next build --webpack",
    "build:encrypted-production": "dotenvx run -f .env.production -- next build --webpack",
    "start": "next start",
    "start:encrypted-production": "dotenvx run -f .env.production -- next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "gitleaks:scan": "gitleaks git --redact",
    "gitleaks:staged": "gitleaks git --staged --redact",
    "payload:types": "dotenvx run -f .env.development -- sh -c 'PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types'",
    "payload:importmap": "dotenvx run -f .env.development -- sh -c 'PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:importmap'",
    "migrate:tags-localized": "tsx --env-file=.env scripts/migrate-tags-to-localized.ts",
    "migrate:team-localized": "tsx --env-file=.env scripts/migrate-team-to-localized.ts",
    "migrate:posts-localized": "tsx --env-file=.env scripts/migrate-posts-to-localized.ts",
    "migrate:certificates-localized": "tsx --env-file=.env scripts/migrate-certificates-to-localized.ts",
    "migrate:seo-fields": "tsx --env-file=.env scripts/run-migration.js",
    "regenerate:images": "tsx --env-file=.env scripts/regenerate-r2-image-sizes.ts",
    "social:backfill": "tsx scripts/backfill-post-social-images.ts",
    "glossary:import": "dotenvx run -f .env.development -- tsx scripts/import-yachting-glossary.ts",
    "glossary:translate": "dotenvx run -f .env.development -- tsx scripts/translate-yachting-glossary.ts",
    "glossary:samples": "dotenvx run -f .env.development -- tsx scripts/generate-encyclopedia-samples.ts",
    "glossary:batch": "dotenvx run -f .env.development -- tsx scripts/generate-encyclopedia-batch.ts",
    "glossary:approve": "dotenvx run -f .env.development -- tsx scripts/approve-encyclopedia.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.901.0",
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/payload-cloud": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-s3": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "graphql": "^16.11.0",
    "jsdom": "^26.1.0",
    "mime-types": "^2.1.35",
    "next": "16.2.10",
    "node-fetch": "^3.3.2",
    "payload": "3.86.0",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^2.15.1",
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^21.1.6",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.19.1",
    "typescript": "^5"
  }
}
