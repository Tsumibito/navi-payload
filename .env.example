# Payload CMS Secret (generate with: openssl rand -base64 32)
PAYLOAD_SECRET=your_secret_here
PAYLOAD_SSG_API_KEY=your_ssg_build_key_here
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Database Connection
DATABASE_URI=postgresql://user:password@host:port/database?search_path=schema
PAYLOAD_DB_SCHEMA=navi
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=60000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000

# Cloudflare R2 Storage
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=your_bucket_name
CLOUDFLARE_R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://your_public_url.r2.dev

# OpenRouter API (для AI функций)
OPENROUTER_TOKEN=sk-or-v1-your_token_here

# Baserow API (для миграции данных, опционально)
BASEROW_API_KEY=your_baserow_api_key

# DataForSEO API (для SEO анализа, опционально)
DATAFORSEO_API_KEY=your_dataforseo_api_key
